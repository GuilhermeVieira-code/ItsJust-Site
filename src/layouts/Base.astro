---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  currentArticleId?: string;
}

const {
  title,
  description = 'Tecnologia emergente e inovação acessíveis para todos.',
  ogImage = '/images/logo.png',
  currentArticleId,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <!-- OG -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | ItsJust`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ItsJust`} />
  <meta name="twitter:description" content={description} />

  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/images/logo.png" type="image/png" />

  <title>{title} | ItsJust</title>

  <!-- View Transitions -->
  <ViewTransitions />
</head>
<body class="min-h-screen flex flex-col bg-cream">

  <!-- Overlay de pétalas para transição de página — persiste durante a troca de DOM -->
  <div id="petal-overlay" transition:persist aria-hidden="true"></div>

  <!-- Sidebar de navegação global (home, sobre, artigos) -->
  <ArticleSidebar currentId={currentArticleId} />

  <Header />
  <main id="page-main" class="flex-1">
    <slot />
  </main>
  <Footer />

  <!-- Scroll reveal global -->
  <script>
    function initReveal() {
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal:not(.visible)');
      if (!revealEls.length) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );
      revealEls.forEach(el => io.observe(el));
    }

    // Roda no load inicial e após cada transição de página
    initReveal();
    document.addEventListener('astro:page-load', initReveal);
  </script>

  <!-- Efeito de pétalas na transição -->
  <script>
    const PETAL_SVG = `
      <svg width="18" height="24" viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 0C9 0 18 8 18 14C18 19.5228 14 24 9 24C4 24 0 19.5228 0 14C0 8 9 0 9 0Z"
              fill="currentColor" opacity="0.85"/>
      </svg>`;

    function spawnPetals(count = 60) {
      const overlay = document.getElementById('petal-overlay');
      if (!overlay) return;
      overlay.innerHTML = '';

      const colors = ['#D4A017', '#F2A900', '#FFD54F', '#E8C547', '#C49010', '#B8860B', '#FBBF24', '#F59E0B'];

      // Distribui pétalas em colunas para cobrir a tela toda
      for (let i = 0; i < count; i++) {
        const scale = (0.6 + Math.random() * 1.8).toFixed(2);
        const rotate = Math.floor(180 + Math.random() * 540);
        const duration = (0.8 + Math.random() * 1.0).toFixed(2);
        // Delay escalonado para que as pétalas desçam em ondas cobrindo a tela
        const delay = (i / count * 0.5 + Math.random() * 0.2).toFixed(2);
        // Distribuição uniforme horizontal: divide a tela em faixas
        const col = i % 10;
        const leftBase = col * 10 + Math.random() * 8;
        const el = document.createElement('div');
        el.className = 'petal-particle';
        el.innerHTML = PETAL_SVG;
        el.style.cssText = `
          position: fixed;
          left: ${leftBase}vw;
          top: ${-6 - Math.random() * 20}vh;
          color: ${colors[Math.floor(Math.random() * colors.length)]};
          --s: ${scale};
          --r: ${rotate}deg;
          animation: petal-fall ${duration}s cubic-bezier(0.3, 0, 0.7, 1) ${delay}s forwards;
          pointer-events: none;
          z-index: 9999;
        `;
        overlay.appendChild(el);
      }

      setTimeout(() => { overlay.innerHTML = ''; }, 2000);
    }

    // Dispara pétalas antes de cada transição de página
    document.addEventListener('astro:before-preparation', () => spawnPetals());
    // Fallback: dispara no before-swap se ainda não houver pétalas
    document.addEventListener('astro:before-swap', () => {
      if (!document.getElementById('petal-overlay')?.children.length) spawnPetals(40);
    });
  </script>

</body>
</html>
