---
interface Props {
  variant?: 'article' | 'page';
}

const { variant = 'article' } = Astro.props;
---

<section class:list={[
  'relative overflow-hidden rounded-2xl',
  variant === 'article' ? 'mt-12 p-7 md:p-10' : 'py-16 px-6 rounded-none',
  'bg-gradient-to-br from-dark-brown via-[#3A2218] to-warm-brown text-cream',
]}>
  <span class="absolute -top-6 -right-6 text-9xl opacity-[0.05] select-none pointer-events-none rotate-12" aria-hidden="true">🌻</span>
  <span class="absolute -bottom-8 -left-8 text-8xl opacity-[0.04] select-none pointer-events-none -rotate-6" aria-hidden="true">🌻</span>

  <div class="relative max-w-xl mx-auto text-center">
    <div class="text-3xl mb-3">🌻</div>
    <h3 class="font-heading italic text-2xl text-light-gold mb-2">
      Espalhe a luz
    </h3>
    <p class="font-body text-sm text-cream/70 mb-8 leading-relaxed max-w-md mx-auto">
      Compartilhe este conteudo e entre na comunidade ItsJust para continuar a conversa com professores, alunos e profissionais.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <button
        type="button"
        data-social-share
        class="social-btn group bg-gold/15 border-gold/40 hover:bg-gold/25"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold group-hover:scale-110 transition-transform">
          <circle cx="18" cy="5" r="3" />
          <circle cx="6" cy="12" r="3" />
          <circle cx="18" cy="19" r="3" />
          <line x1="8.6" y1="13.5" x2="15.4" y2="17.5" />
          <line x1="15.4" y1="6.5" x2="8.6" y2="10.5" />
        </svg>
        <span data-share-label class="text-gold">Compartilhar</span>
      </button>

      <a href="/comunidade" class="social-btn group bg-gold/15 border-gold/40 hover:bg-gold/25">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold group-hover:scale-110 transition-transform">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        <span class="text-gold">Comunidade</span>
      </a>

      <a
        href="https://www.linkedin.com/in/guilherme-domingues-19221019a"
        target="_blank"
        rel="noopener noreferrer"
        class="social-btn group"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[#0A66C2] group-hover:scale-110 transition-transform">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        LinkedIn
      </a>

      <a
        href="https://www.youtube.com/@ItsJust-j1q"
        target="_blank"
        rel="noopener noreferrer"
        class="social-btn group"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[#FF0000] group-hover:scale-110 transition-transform">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
        </svg>
        YouTube
      </a>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-2 mt-3">
      <a
        href="https://chat.whatsapp.com/LGXJFtC48bd273R25xtEWt"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-white/15 bg-white/5 text-cream/80 font-body text-xs hover:bg-white/10 hover:text-cream transition-colors no-underline"
      >
        Subgrupo Alunos
      </a>
      <a
        href="https://chat.whatsapp.com/CsHgveCIj1235a38zlg7XO"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-white/15 bg-white/5 text-cream/80 font-body text-xs hover:bg-white/10 hover:text-cream transition-colors no-underline"
      >
        Subgrupo Professores
      </a>
    </div>

    <p class="font-heading italic text-xs text-cream/40 mt-8">
      Cada petala de luz compartilhada ilumina um pouco mais o mundo.
    </p>
  </div>
</section>

<style>
  .social-btn {
    @apply inline-flex items-center gap-2 px-5 py-2.5
           font-body text-sm font-semibold text-cream
           bg-white/10 border border-white/15
           rounded-xl
           hover:bg-white/15 hover:border-white/30
           transition-all duration-200
           shadow-[0_2px_8px_rgba(0,0,0,0.15)]
           hover:shadow-[0_4px_16px_rgba(0,0,0,0.2)]
           hover:-translate-y-0.5
           no-underline;
  }
</style>

<script is:inline>
  (() => {
    const initShare = () => {
      document.querySelectorAll('[data-social-share]').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        if (button.dataset.bound === '1') return;
        button.dataset.bound = '1';

        const label = button.querySelector('[data-share-label]');
        const defaultText = label?.textContent ?? 'Compartilhar';
        let feedbackTimer = 0;

        const setLabel = (text) => {
          if (!label) return;
          label.textContent = text;
          if (feedbackTimer) window.clearTimeout(feedbackTimer);
          feedbackTimer = window.setTimeout(() => {
            label.textContent = defaultText;
          }, 1800);
        };

        button.addEventListener('click', async () => {
          const url = window.location.href;
          const title = document.title.replace(/\s*\|\s*ItsJust$/i, '');
          const text = 'Li este artigo, ele me ajudou, e quis compartilhar essa luz com voce.';

          if (navigator.share) {
            try {
              await navigator.share({ title, text, url });
              return;
            } catch (error) {
              if (error && typeof error === 'object' && 'name' in error && error.name === 'AbortError') return;
            }
          }

          try {
            await navigator.clipboard.writeText(url);
            setLabel('Link copiado');
          } catch {
            window.prompt('Copie o link:', url);
          }
        });
      });
    };

    initShare();
    document.addEventListener('astro:page-load', initShare);
  })();
</script>
