---
interface Props {
  variant?: 'article' | 'page'; // article = compacto no final do post, page = seção completa
}
const { variant = 'article' } = Astro.props;
---

<section class:list={[
  'relative overflow-hidden rounded-2xl',
  variant === 'article'
    ? 'mt-10 p-7 md:p-10'
    : 'py-16 px-6 rounded-none',
  'bg-gradient-to-br from-dark-brown via-[#3A2218] to-warm-brown text-cream',
]}>

  <!-- Girassóis decorativos de fundo -->
  <span class="absolute -top-6 -right-6 text-9xl opacity-[0.05] select-none pointer-events-none rotate-12" aria-hidden="true">🌻</span>
  <span class="absolute -bottom-8 -left-8 text-8xl opacity-[0.04] select-none pointer-events-none -rotate-6" aria-hidden="true">🌻</span>

  <div class="relative max-w-lg mx-auto text-center">

    <!-- Headline -->
    <div class="text-3xl mb-3">🌻</div>
    <h3 class="font-heading italic text-2xl text-light-gold mb-2">
      Espalhe a luz
    </h3>
    <p class="font-body text-sm text-cream/70 mb-8 leading-relaxed max-w-sm mx-auto">
      Faça parte da comunidade ItsJust — onde tecnologia e pessoas se encontram para uma conversa leve, honesta e cheia de significado.
    </p>

    <!-- Botões sociais -->
    <div class="flex flex-wrap items-center justify-center gap-3">

      <!-- LinkedIn -->
      <a
        href="https://linkedin.com/in/guilherme-domingues"
        target="_blank"
        rel="noopener noreferrer"
        class="social-btn group"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[#0A66C2] group-hover:scale-110 transition-transform">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>

      <!-- YouTube -->
      <a
        href="https://youtube.com/@itsjust"
        target="_blank"
        rel="noopener noreferrer"
        class="social-btn group"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-[#FF0000] group-hover:scale-110 transition-transform">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        YouTube
      </a>

      <!-- Newsletter / Comunidade -->
      <a
        href="mailto:guivdom@gmail.com?subject=Quero%20fazer%20parte%20da%20comunidade%20ItsJust"
        class="social-btn group bg-gold/15 border-gold/40 hover:bg-gold/25"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold group-hover:scale-110 transition-transform">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        <span class="text-gold">Comunidade</span>
      </a>

    </div>

    <!-- Tagline -->
    <p class="font-heading italic text-xs text-cream/40 mt-8">
      Cada pétala de luz, compartilhada, ilumina um pouco mais o mundo. 🌻
    </p>

  </div>
</section>

<style>
  .social-btn {
    @apply inline-flex items-center gap-2 px-5 py-2.5
           font-body text-sm font-semibold text-cream
           bg-white/10 border border-white/15
           rounded-xl
           hover:bg-white/15 hover:border-white/30
           transition-all duration-200
           shadow-[0_2px_8px_rgba(0,0,0,0.15)]
           hover:shadow-[0_4px_16px_rgba(0,0,0,0.2)]
           hover:-translate-y-0.5
           no-underline;
  }
</style>
