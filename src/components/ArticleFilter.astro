---
import ArticleCard from './ArticleCard.astro';
import { getArticleSlug } from '../content/config';

interface Article {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    section: string;
    subtopic: string;
    tags: string[];
    cover?: string;
    video?: string;
  };
}

interface Props {
  articles: Article[];
  showSectionFilter?: boolean;
}

const { articles, showSectionFilter = false } = Astro.props;

// Coleta subtópicos únicos presentes nos artigos
const subtopics = [...new Set(articles.map(a => a.data.subtopic))];
const sections  = [...new Set(articles.map(a => a.data.section))];
---

<div id="filter-root">

  <!-- Barra de busca + filtros -->
  <div class="flex flex-col gap-4 mb-8">

    <!-- Input de busca -->
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-warm-gray w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Buscar artigos..."
        class="w-full pl-9 pr-4 py-2.5 bg-card-bg border border-[#E8DCC8] rounded font-body text-sm text-dark-brown placeholder-warm-gray focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition"
      />
    </div>

    <!-- Filtros por tema -->
    <div class="flex flex-wrap gap-2" id="filter-buttons">
      <button
        data-filter="all"
        class="filter-btn active font-body text-xs font-semibold px-4 py-1.5 rounded-sm border transition-all"
      >
        Todos
      </button>

      {showSectionFilter && sections.map(section => (
        <button
          data-filter={`section:${section}`}
          data-label={section.replace('ItsJust', '')}
          class="filter-btn font-body text-xs font-semibold px-4 py-1.5 rounded-sm border transition-all"
        >
          {section.replace('ItsJust', 'ItsJust ')}
        </button>
      ))}

      {subtopics.map(subtopic => (
        <button
          data-filter={`subtopic:${subtopic}`}
          data-label={subtopic.replace('ItsJust', '')}
          class="filter-btn font-body text-xs font-semibold px-4 py-1.5 rounded-sm border transition-all"
        >
          {subtopic.replace('ItsJust', '')}
        </button>
      ))}
    </div>
  </div>

  <!-- Grid de artigos -->
  <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {articles.map(article => (
      <div
        class="article-item"
        data-title={article.data.title.toLowerCase()}
        data-description={article.data.description.toLowerCase()}
        data-tags={article.data.tags.join(' ').toLowerCase()}
        data-subtopic={article.data.subtopic}
        data-section={article.data.section}
      >
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          section={article.data.section}
          subtopic={article.data.subtopic}
          slug={getArticleSlug(article)}
          tags={article.data.tags}
          cover={article.data.cover}
          video={article.data.video}
        />
      </div>
    ))}
  </div>

  <!-- Estado vazio -->
  <p id="empty-state" class="hidden font-body text-warm-gray text-center py-12">
    Nenhum artigo encontrado para essa busca. 🌻
  </p>
</div>

<style>
  .filter-btn {
    background-color: transparent;
    border-color: #E8DCC8;
    color: #8B7355;
  }
  .filter-btn:hover {
    border-color: #D4A017;
    color: #D4A017;
  }
  .filter-btn.active {
    background-color: #D4A017;
    border-color: #D4A017;
    color: #2C1810;
  }
</style>

<script>
  const searchInput  = document.getElementById('search-input') as HTMLInputElement;
  const buttons      = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items        = document.querySelectorAll<HTMLElement>('.article-item');
  const emptyState   = document.getElementById('empty-state')!;

  let activeFilter = 'all';
  let searchQuery  = '';

  function applyFilters() {
    let visible = 0;

    items.forEach(item => {
      const title       = item.dataset.title ?? '';
      const description = item.dataset.description ?? '';
      const tags        = item.dataset.tags ?? '';
      const subtopic    = item.dataset.subtopic ?? '';
      const section     = item.dataset.section ?? '';

      // Verifica filtro de tema
      let matchesFilter = activeFilter === 'all';
      if (activeFilter.startsWith('subtopic:')) {
        matchesFilter = subtopic === activeFilter.replace('subtopic:', '');
      } else if (activeFilter.startsWith('section:')) {
        matchesFilter = section === activeFilter.replace('section:', '');
      }

      // Verifica busca por texto
      const q = searchQuery.toLowerCase().trim();
      const matchesSearch = !q || title.includes(q) || description.includes(q) || tags.includes(q);

      if (matchesFilter && matchesSearch) {
        item.style.display = '';
        visible++;
      } else {
        item.style.display = 'none';
      }
    });

    emptyState.classList.toggle('hidden', visible > 0);
  }

  // Filtros por tema
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });

  // Busca por texto
  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value;
    applyFilters();
  });
</script>
