---
// ItsJust Tools & Solutions
// Ferramentas próprias (GitHub ItsJust-Code) + parcerias

const OWN_TOOLS = [
  {
    name: 'ItsJustNotes',
    type: 'open-source',
    status: 'live',
    color: '#D4A017',
    bg: '#2a1e05',
    initials: 'IN',
    url: 'https://github.com/ItsJust-Code/ItsJustNotes',
    desc: 'Sistema de notas com Zettelkasten + PARA para organizar conhecimento em IA.',
    tags: ['Obsidian', 'Knowledge'],
  },
  {
    name: 'Local ML Translator',
    type: 'open-source',
    status: 'soon',
    color: '#4ade80',
    bg: '#0f2018',
    initials: 'LM',
    url: 'https://github.com/ItsJust-Code/Local-ML-Translator',
    desc: 'Tradutor local com modelos de ML — sem enviar dados para a nuvem.',
    tags: ['Python', 'ML', 'Privacy'],
  },
  {
    name: 'Breast Cancer Classifier',
    type: 'open-source',
    status: 'soon',
    color: '#f472b6',
    bg: '#200d1a',
    initials: 'BC',
    url: 'https://github.com/ItsJust-Code/Breast-Cancer-Classification',
    desc: 'Classificação de câncer de mama com machine learning e explicabilidade.',
    tags: ['Python', 'HealthTech'],
  },
];

const PARTNER_SLOTS = [
  {
    name: 'Parceria em breve',
    type: 'partner',
    status: 'soon',
    color: '#60a5fa',
    bg: '#0f172a',
    initials: '?',
    url: '#',
    desc: 'Estamos selecionando parceiros que compartilham a missão do ItsJust.',
    tags: [],
  },
  {
    name: 'Parceria em breve',
    type: 'partner',
    status: 'soon',
    color: '#a78bfa',
    bg: '#1a0d2e',
    initials: '?',
    url: '#',
    desc: 'Ferramentas e soluções de IA curadas pelo ItsJust.',
    tags: [],
  },
];

const ALL_TOOLS = [...OWN_TOOLS, ...PARTNER_SLOTS];

const STATUS_LABEL: Record<string, string> = {
  live: 'Disponível',
  soon: 'Em breve',
};

const TYPE_LABEL: Record<string, string> = {
  'open-source': 'Open Source',
  'partner': 'Parceria',
};
---

<section id="ferramentas" class="py-14 px-5 bg-dark-brown overflow-hidden">
  <div class="max-w-content mx-auto mb-8">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <span class="font-body text-xs font-semibold tracking-widest text-gold/60 uppercase mb-1 block">Feito pelo ItsJust &amp; parceiros</span>
        <h2 class="font-heading font-bold text-2xl text-cream">ItsJust <span class="text-gold">Tools</span></h2>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/ItsJust-Code"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/15 rounded-lg font-body text-xs text-cream/70 hover:text-cream hover:bg-white/15 transition-all no-underline"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          ItsJust-Code no GitHub
        </a>
        <p class="hidden md:block font-body text-sm text-cream/40 max-w-xs">
          Ferramentas open-source e parcerias curadas pelo ItsJust.
        </p>
      </div>
    </div>
  </div>

  <!-- Cards das ferramentas -->
  <div class="relative">
    <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-dark-brown to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-dark-brown to-transparent z-10 pointer-events-none"></div>

    <div
      id="tools-track"
      class="flex gap-5 overflow-x-auto pb-4 px-5 scroll-smooth"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      {ALL_TOOLS.map(tool => (
        <a
          href={tool.status === 'live' ? tool.url : undefined}
          target={tool.status === 'live' ? '_blank' : undefined}
          rel={tool.status === 'live' ? 'noopener noreferrer' : undefined}
          class:list={[
            'tool-card flex-shrink-0 w-64 rounded-2xl p-5 flex flex-col gap-4 no-underline group transition-all duration-200',
            tool.status === 'live' ? 'hover:-translate-y-1 cursor-pointer' : 'cursor-default opacity-75',
          ]}
          style={`background: ${tool.bg}; border: 1px solid ${tool.color}25;`}
        >
          <!-- Header -->
          <div class="flex items-start justify-between gap-2">
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center font-heading font-bold text-sm flex-shrink-0"
              style={`background: ${tool.color}18; color: ${tool.color}; border: 1px solid ${tool.color}30;`}
            >
              {tool.initials}
            </div>
            <div class="flex flex-col items-end gap-1 flex-shrink-0">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full"
                style={`background: ${tool.color}18; color: ${tool.color};`}
              >
                {TYPE_LABEL[tool.type]}
              </span>
              <span class:list={[
                'text-[10px] font-semibold px-2 py-0.5 rounded-full',
                tool.status === 'live'
                  ? 'bg-green-500/15 text-green-400'
                  : 'bg-white/10 text-white/40',
              ]}>
                {STATUS_LABEL[tool.status]}
              </span>
            </div>
          </div>

          <!-- Conteúdo -->
          <div class="flex-1">
            <p class:list={[
              'font-heading font-bold text-base mb-2 transition-colors',
              tool.status === 'live'
                ? 'text-cream group-hover:text-gold'
                : 'text-cream/50',
            ]}>
              {tool.name}
            </p>
            <p class="font-body text-xs text-cream/50 leading-relaxed">{tool.desc}</p>
          </div>

          <!-- Tags -->
          {tool.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {tool.tags.map(tag => (
                <span
                  class="text-[10px] px-2 py-0.5 rounded font-mono"
                  style={`background: ${tool.color}12; color: ${tool.color}; opacity: 0.8;`}
                >
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- CTA -->
          {tool.status === 'live' && (
            <div class="flex items-center gap-1.5 text-[11px] font-semibold opacity-0 group-hover:opacity-100 transition-opacity" style={`color: ${tool.color};`}>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Ver no GitHub →
            </div>
          )}
        </a>
      ))}

      <!-- Card "quer ser parceiro?" -->
      <a
        href="mailto:contatoitsjust@gmail.com?subject=Parceria%20ItsJust%20Tools"
        class="tool-card flex-shrink-0 w-56 rounded-2xl p-5 flex flex-col items-center justify-center gap-3 no-underline group hover:-translate-y-1 transition-all duration-200 cursor-pointer"
        style="background: rgba(212,160,23,0.04); border: 1px dashed rgba(212,160,23,0.25);"
      >
        <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center border border-gold/20 group-hover:bg-gold/15 transition-colors">
          <span class="text-2xl">🤝</span>
        </div>
        <div class="text-center">
          <p class="font-heading font-bold text-sm text-gold/70 group-hover:text-gold transition-colors mb-1">Quer ser parceiro?</p>
          <p class="font-body text-xs text-cream/40 leading-snug">Tem uma ferramenta ou solução para compartilhar com a comunidade ItsJust?</p>
        </div>
        <span class="text-xs font-semibold text-gold/50 group-hover:text-gold transition-colors">Entre em contato →</span>
      </a>
    </div>
  </div>

  <!-- Controles -->
  <div class="flex items-center justify-center gap-3 mt-6">
    <button id="tools-prev" class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:text-gold hover:border-gold/40 transition-all" aria-label="Anterior">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <span class="font-body text-xs text-cream/30">{OWN_TOOLS.length} ferramentas · {PARTNER_SLOTS.length} parcerias</span>
    <button id="tools-next" class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:text-gold hover:border-gold/40 transition-all" aria-label="Próxima">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>
</section>

<style>
  #tools-track::-webkit-scrollbar { display: none; }
  .tool-card { box-shadow: 0 2px 12px rgba(0,0,0,0.25); }
  .tool-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
</style>

<script>
  const track = document.getElementById('tools-track');
  const cardW = 256 + 20; // w-64 (256px) + gap-5 (20px)
  document.getElementById('tools-prev')?.addEventListener('click', () => {
    track?.scrollBy({ left: -cardW * 2, behavior: 'smooth' });
  });
  document.getElementById('tools-next')?.addEventListener('click', () => {
    track?.scrollBy({ left: cardW * 2, behavior: 'smooth' });
  });
</script>
