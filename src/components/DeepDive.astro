---
interface Resource {
  title: string;
  url: string;
  type?: 'youtube' | 'podcast' | 'newsletter' | 'course' | 'article';
  description?: string;
  author?: string;
  language?: 'pt-BR' | 'en' | 'es' | 'other';
  priority?: number;
}

interface NormalizedResource extends Resource {
  type: 'youtube' | 'podcast' | 'newsletter' | 'course' | 'article';
  language: 'pt-BR' | 'en' | 'es' | 'other';
  priority: number;
}

interface Props {
  extra?: Resource[];
}

const { extra = [] } = Astro.props;

const TYPE_CONFIG: Record<NormalizedResource['type'], { label: string; icon: string; bg: string; text: string; border: string }> = {
  youtube:    { label: 'YouTube',    icon: '▶',  bg: 'bg-red-50',     text: 'text-red-600',     border: 'border-red-200' },
  podcast:    { label: 'Podcast',    icon: '🎙', bg: 'bg-blue-50',    text: 'text-blue-600',    border: 'border-blue-200' },
  newsletter: { label: 'Newsletter', icon: '📰', bg: 'bg-sky-50',     text: 'text-sky-600',     border: 'border-sky-200' },
  course:     { label: 'Curso',      icon: '📚', bg: 'bg-emerald-50', text: 'text-emerald-600', border: 'border-emerald-200' },
  article:    { label: 'Artigo',     icon: '📝', bg: 'bg-amber-50',   text: 'text-amber-600',   border: 'border-amber-200' },
};

const PT_HINTS = ['pt-br', 'portugues', 'português', 'brasil', 'brasileiro', 'brasileira'];
const TYPE_ORDER: Record<NormalizedResource['type'], number> = {
  article: 1,
  course: 2,
  podcast: 3,
  youtube: 4,
  newsletter: 5,
};

function inferLanguage(resource: Resource): NormalizedResource['language'] {
  if (resource.language) return resource.language;

  const text = `${resource.title} ${resource.description ?? ''} ${resource.author ?? ''}`.toLowerCase();
  if (PT_HINTS.some((hint) => text.includes(hint))) return 'pt-BR';
  if (/[áàâãéêíóôõúç]/i.test(text)) return 'pt-BR';

  try {
    const host = new URL(resource.url).hostname.toLowerCase();
    if (host.endsWith('.br')) return 'pt-BR';
  } catch {
    // no-op
  }

  return 'other';
}

const normalized: NormalizedResource[] = extra.map((resource) => ({
  ...resource,
  type: resource.type ?? 'article',
  language: inferLanguage(resource),
  priority: resource.priority ?? 3,
}));

const sorted = normalized.sort((a, b) => {
  const languageScore = (a.language === 'pt-BR' ? 2 : 0) - (b.language === 'pt-BR' ? 2 : 0);
  if (languageScore !== 0) return -languageScore;
  if (a.priority !== b.priority) return b.priority - a.priority;
  if (a.type !== b.type) return TYPE_ORDER[a.type] - TYPE_ORDER[b.type];
  return a.title.localeCompare(b.title, 'pt-BR');
});

const featured = sorted.slice(0, 4);
const remaining = sorted.slice(4);
const ptCount = sorted.filter((r) => r.language === 'pt-BR').length;

const languageTag = (language: NormalizedResource['language']) => {
  if (language === 'pt-BR') return { label: 'PT-BR', className: 'bg-emerald-50 text-emerald-700 border-emerald-200' };
  if (language === 'en') return { label: 'EN', className: 'bg-slate-50 text-slate-600 border-slate-200' };
  if (language === 'es') return { label: 'ES', className: 'bg-slate-50 text-slate-600 border-slate-200' };
  return { label: 'Outro', className: 'bg-slate-50 text-slate-600 border-slate-200' };
};
---

{sorted.length > 0 && (
  <section class="mt-14 border-t border-[#E8DCC8] pt-10">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-2xl select-none" aria-hidden="true">🌻</span>
      <div>
        <h2 class="font-heading font-bold text-xl text-dark-brown leading-tight">
          Se aprofunde em outros conteúdos
        </h2>
        <p class="font-body text-sm text-warm-gray mt-0.5">
          Priorizamos referências em português para facilitar sua jornada.
        </p>
      </div>
    </div>

    <p class="font-body text-xs text-warm-gray mb-5">
      {ptCount} de {sorted.length} referência{sorted.length !== 1 ? 's' : ''} em PT-BR.
    </p>

    <div class="grid sm:grid-cols-2 gap-3">
      {featured.map((resource) => {
        const config = TYPE_CONFIG[resource.type];
        const language = languageTag(resource.language);
        return (
          <a
            href={resource.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex gap-3 p-4 rounded-xl border border-[#E8DCC8] bg-card-bg hover:border-gold/40 hover:bg-[#FFFBF0] transition-all duration-200 no-underline"
          >
            <div class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 text-sm ${config.bg} ${config.text} border ${config.border}`}>
              {config.icon}
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-2">
                <p class="font-heading font-bold text-sm text-dark-brown group-hover:text-gold transition-colors duration-150 leading-snug">
                  {resource.title}
                </p>
                <span class={`inline-flex px-2 py-0.5 rounded border text-[10px] font-semibold font-body flex-shrink-0 ${language.className}`}>
                  {language.label}
                </span>
              </div>
              <p class="font-body text-[10px] text-warm-gray mt-0.5">
                {resource.author ?? config.label}
              </p>
              {resource.description && (
                <p class="font-body text-xs text-warm-gray mt-1.5 leading-snug line-clamp-2">
                  {resource.description}
                </p>
              )}
            </div>
          </a>
        );
      })}
    </div>

    {remaining.length > 0 && (
      <details class="mt-4 rounded-xl border border-[#E8DCC8] bg-[#FFFBF0]">
        <summary class="cursor-pointer list-none px-4 py-3 font-body text-sm font-semibold text-dark-brown flex items-center justify-between">
          <span>Ver mais referências ({remaining.length})</span>
          <span class="text-gold">↓</span>
        </summary>

        <div class="px-3 pb-3">
          <div class="max-h-[22rem] overflow-y-auto overscroll-contain pr-1 grid sm:grid-cols-2 gap-3">
            {remaining.map((resource) => {
              const config = TYPE_CONFIG[resource.type];
              const language = languageTag(resource.language);
              return (
                <a
                  href={resource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex gap-3 p-3 rounded-lg border border-[#E8DCC8] bg-card-bg hover:border-gold/40 hover:bg-white transition-all duration-200 no-underline"
                >
                  <div class={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-xs ${config.bg} ${config.text} border ${config.border}`}>
                    {config.icon}
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-start justify-between gap-2">
                      <p class="font-heading font-bold text-xs text-dark-brown group-hover:text-gold transition-colors duration-150 leading-snug">
                        {resource.title}
                      </p>
                      <span class={`inline-flex px-1.5 py-0.5 rounded border text-[9px] font-semibold font-body flex-shrink-0 ${language.className}`}>
                        {language.label}
                      </span>
                    </div>
                    <p class="font-body text-[10px] text-warm-gray mt-0.5">
                      {resource.author ?? config.label}
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </details>
    )}
  </section>
)}
