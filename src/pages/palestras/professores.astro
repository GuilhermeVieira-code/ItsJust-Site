  </section>

  <section class="px-5 pt-4 pb-2">
    <div class="max-w-content mx-auto grid grid-cols-2 sm:grid-cols-5 gap-2">
      <a href="#grupo" class="rounded-lg border border-[#E8DCC8] bg-off-white px-3 py-2 text-center no-underline font-body text-xs font-semibold text-dark-brown hover:border-gold/40 transition-colors">Grupo</a>
