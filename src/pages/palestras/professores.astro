        <p class="font-body text-xs text-warm-gray mt-0.5">Regras e ecossistema</p>
      </a>
      <a href="https://chat.whatsapp.com/ITOStJuXenb0okjlxjuiNI" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-[#E8DCC8] bg-off-white px-4 py-3 no-underline hover:border-gold/40 transition-colors">
