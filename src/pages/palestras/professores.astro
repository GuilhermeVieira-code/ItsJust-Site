---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SECTION_SLUG, SUBTOPIC_SLUG, getArticleSlug, isPublicArticleStatus } from '../../content/config';

const prioritySlugs = [
  'a-nova-sala-de-aula-como-ensinar-com-ia',
  'o-professor-e-o-que-a-ia-nao-consegue-ser',
  'ia-como-superpoder-do-professor',
  'aprender-junto-e-mais-forte-do-que-cobrar',
  'como-falar-sobre-ia-quando-parece-demais',
] as const;

const allArticles = await getCollection('articles', ({ data }) => isPublicArticleStatus(data.status));
const bySlug = new Map(allArticles.map((article) => [getArticleSlug(article), article]));
const relevantArticles = prioritySlugs
  .map((slug) => bySlug.get(slug))
  .filter((article): article is (typeof allArticles)[number] => Boolean(article));

function getArticleHref(article: (typeof allArticles)[number]): string {
  const section = SECTION_SLUG[article.data.section as keyof typeof SECTION_SLUG];
  const subtopic = SUBTOPIC_SLUG[article.data.subtopic as keyof typeof SUBTOPIC_SLUG];
  return `/${section}/${subtopic}/${getArticleSlug(article)}`;
}
---

