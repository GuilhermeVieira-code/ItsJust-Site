              <p class="font-body text-xs font-semibold text-gold mt-3">Ler agora -></p>
            </a>
          ))}
        </div>
      </div>

      <div class="hidden md:grid md:grid-cols-2 gap-3">
        {relevantArticles.map((article, index) => (
          <a href={getArticleHref(article)} class="rounded-xl border border-[#E8DCC8] bg-off-white p-4 no-underline hover:border-gold/40 transition-colors">
