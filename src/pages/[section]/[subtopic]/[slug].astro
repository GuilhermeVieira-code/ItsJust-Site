---
import { getCollection, render } from 'astro:content';
import Article from '../../../layouts/Article.astro';
import { SECTION_SLUG, SUBTOPIC_SLUG } from '../../../content/config';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.status === 'published');
  return articles.map(article => ({
    params: {
      section:  SECTION_SLUG[article.data.section as keyof typeof SECTION_SLUG],
      subtopic: SUBTOPIC_SLUG[article.data.subtopic as keyof typeof SUBTOPIC_SLUG],
      slug:     article.id,
    },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

// Todos os artigos publicados (para relacionados)
const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');

// Artigos do mesmo subtópico (para sidebar)
const subtopicArticles = allArticles.filter(
  a => a.data.subtopic === article.data.subtopic
);
---

<Article
  title={article.data.title}
  description={article.data.description}
  date={article.data.date}
  updated={article.data.updated}
  section={article.data.section}
  subtopic={article.data.subtopic}
  tags={article.data.tags}
  video={article.data.video}
  resources={article.data.resources}
  deepdive={article.data.deepdive}
  headings={headings}
  currentId={article.id}
  subtopicArticles={subtopicArticles}
  allArticles={allArticles}
>
  <Content />
</Article>
