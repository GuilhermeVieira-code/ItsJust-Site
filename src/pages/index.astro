---
import Base from '../layouts/Base.astro';
import ArticleFilter from '../components/ArticleFilter.astro';
import ToolsCarousel from '../components/ToolsCarousel.astro';
import KnowledgeGraph from '../components/KnowledgeGraph.astro';
import PartnershipChatPopup from '../components/PartnershipChatPopup.astro';
import { getCollection } from 'astro:content';
import { isPublicArticleStatus } from '../content/config';

const allArticles = await getCollection('articles', ({ data }) => isPublicArticleStatus(data.status));
const sorted = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="ItsJust — Compartilhe sua luz">

  <!-- ─── Hero ───────────────────────────────────────── -->
  <section class="bg-dark-brown text-cream py-16 px-5 relative overflow-hidden">
    <span class="absolute top-6 right-[45%] text-8xl opacity-[0.03] select-none pointer-events-none" aria-hidden="true">🌻</span>
    <span class="absolute bottom-8 left-8 text-6xl opacity-[0.03] select-none pointer-events-none rotate-12" aria-hidden="true">🌻</span>

    <div class="max-w-content mx-auto relative">
      <!-- Layout 2 colunas: texto à esquerda, grafo à direita -->
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-14">

        <!-- Coluna esquerda — texto + CTAs -->
        <div class="flex-1 min-w-0 max-w-xl">
          <!-- Pretítulo -->
          <div class="flex items-center gap-3 mb-5 reveal">
            <img src="/images/logo.png" alt="ItsJust" width="36" height="36" class="w-9 h-9" />
            <span class="font-body text-xs font-semibold tracking-widest text-gold/70 uppercase">ItsJust</span>
          </div>

          <h1 class="font-heading font-bold text-4xl md:text-[3.25rem] leading-tight mb-5 text-cream reveal reveal-delay-1">
            Compartilhe<br />
            <span class="text-gold">sua luz. 🌻</span>
          </h1>

          <p class="font-body text-lg text-cream/65 max-w-xl mb-2 leading-relaxed reveal reveal-delay-2">
            Um espaço aberto para explorar IA, inovação e o futuro — com leveza, curiosidade e sem jargão desnecessário.
          </p>
          <p class="font-heading italic text-sm text-gold/50 mb-10 reveal reveal-delay-3">
            Que cada leitura seja como uma pétala — simples, mas cheia de significado. 🌻
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3 reveal reveal-delay-3">
            <a
              href="#artigos"
              class="inline-flex items-center gap-2 px-6 py-3 bg-gold text-dark-brown font-heading font-bold text-sm rounded-xl hover:bg-amber transition-all duration-200 shadow-[0_4px_20px_rgba(212,160,23,0.35)] hover:shadow-[0_6px_28px_rgba(212,160,23,0.45)] hover:-translate-y-0.5 no-underline"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              Explorar artigos
            </a>

            <a
              href="/comunidade"
              class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-cream font-body font-semibold text-sm rounded-xl border border-white/15 hover:bg-white/15 hover:border-white/25 transition-all duration-200 hover:-translate-y-0.5 no-underline"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Entre na comunidade
            </a>

            <a
              href="/sobre"
              class="inline-flex items-center gap-2 px-6 py-3 text-cream/60 font-body text-sm rounded-xl border border-white/10 hover:text-cream hover:border-white/20 transition-all duration-200 no-underline"
            >
              Sobre o ItsJust
              <span class="opacity-40">→</span>
            </a>
          </div>
        </div>

        <!-- Coluna direita — grafo de conhecimento -->
        <div class="w-full lg:w-[480px] xl:w-[540px] flex-shrink-0 reveal reveal-delay-2">
          <div class="relative">
            <!-- Label flutuante -->
            <div class="absolute -top-6 left-0 flex items-center gap-2 z-10">
              <span class="font-body text-[10px] font-semibold tracking-widest text-gold/50 uppercase">Zettelkasten</span>
              <div class="h-px flex-1 w-8 bg-gold/20"></div>
            </div>
            <!-- Container do grafo com borda sutil -->
            <div class="rounded-2xl overflow-hidden border border-white/[0.06] bg-[rgba(20,10,6,0.4)] backdrop-blur-sm" style="height: 440px;">
              <KnowledgeGraph articles={sorted} />
            </div>
            <!-- Hint interativo -->
            <p class="text-center font-body text-[10px] text-cream/25 mt-2">
              Arraste os nós • Passe o mouse para explorar • Clique para ler
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── ItsJust Tools — carrossel ───────────────────── -->
  <ToolsCarousel />

  <!-- ─── Artigos + coluna de contato ─────────────────── -->
  {sorted.length > 0 && (
    <section id="artigos" class="py-14 px-5 pb-20">
      <div class="max-w-content mx-auto">

        <!-- Layout de 2 colunas em telas grandes -->
        <div class="flex gap-10 items-start">

          <!-- Coluna principal — artigos -->
          <div class="flex-1 min-w-0">
            <h2 class="font-heading font-bold text-2xl text-dark-brown mb-8 reveal">Artigos</h2>
            <div class="reveal reveal-delay-1">
              <ArticleFilter articles={sorted} showSectionFilter={false} cardLayout="horizontal" />
            </div>
          </div>

          <!-- Coluna lateral — contato + destaque -->
          <aside class="hidden xl:flex flex-col gap-5 w-72 flex-shrink-0 sticky top-24">

            <!-- Card Entre em contato -->
            <div class="rounded-2xl bg-dark-brown text-cream p-6 relative overflow-hidden">
              <span class="absolute -top-4 -right-4 text-7xl opacity-[0.07] select-none pointer-events-none rotate-12" aria-hidden="true">🌻</span>
              <div class="relative">
                <div class="text-2xl mb-3">✉️</div>
                <h3 class="font-heading font-bold text-base text-light-gold mb-2">Entre em contato</h3>
                <p class="font-body text-xs text-cream/60 leading-relaxed mb-4">
                  Palestras, parcerias, projetos de IA ou só bater um papo sobre tecnologia — fique à vontade.
                </p>
                <a
                  href="mailto:contatoitsjust@gmail.com?subject=Contato%20ItsJust"
                  class="inline-flex items-center gap-2 w-full justify-center px-4 py-2.5 bg-gold text-dark-brown font-body font-semibold text-sm rounded-xl hover:bg-amber transition-all duration-200 no-underline shadow-[0_2px_12px_rgba(212,160,23,0.3)] hover:-translate-y-0.5"
                >
                  contatoitsjust@gmail.com
                </a>
                <div class="flex gap-2 mt-3">
                  <a href="https://www.linkedin.com/in/guilherme-domingues-19221019a" target="_blank" rel="noopener noreferrer"
                    class="flex-1 inline-flex items-center justify-center gap-1.5 py-2 bg-white/10 border border-white/15 rounded-lg font-body text-xs text-cream/70 hover:text-cream hover:bg-white/15 transition-all no-underline">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    LinkedIn
                  </a>
                  <a href="https://www.youtube.com/@ItsJust-j1q" target="_blank" rel="noopener noreferrer"
                    class="flex-1 inline-flex items-center justify-center gap-1.5 py-2 bg-white/10 border border-white/15 rounded-lg font-body text-xs text-cream/70 hover:text-cream hover:bg-white/15 transition-all no-underline">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    YouTube
                  </a>
                </div>
              </div>
            </div>

            <!-- Card — Sobre o ItsJust -->
            <a href="/sobre" class="rounded-2xl border border-[#E8DCC8] bg-off-white p-5 no-underline group hover:border-gold/40 transition-all duration-200">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg bg-gold/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                  <img src="/images/logo.png" alt="" width="18" height="18" class="w-[18px] h-[18px]" />
                </div>
                <div>
                  <p class="font-heading font-bold text-sm text-dark-brown group-hover:text-gold transition-colors">Sobre o ItsJust</p>
                  <p class="font-body text-xs text-warm-gray mt-1 leading-snug">O girassol, a missão e quem está por trás disso tudo.</p>
                </div>
              </div>
              <div class="mt-3 flex items-center justify-end text-xs font-semibold text-gold/50 group-hover:text-gold transition-colors gap-1">
                <span>Conhecer</span>
                <span class="group-hover:translate-x-0.5 transition-transform">→</span>
              </div>
            </a>

            <!-- Stats visuais -->
            <div class="rounded-2xl border border-[#E8DCC8] bg-off-white p-5">
              <p class="font-body text-xs font-semibold text-warm-gray uppercase tracking-wider mb-4">ItsJust em números</p>
              <div class="grid grid-cols-2 gap-3">
                {[
                  { n: sorted.length.toString(), label: 'artigos publicados' },
                  { n: '7',  label: 'tópicos cobertos' },
                  { n: '25+', label: 'sessões de treinamento' },
                  { n: '250+', label: 'profissionais treinados' },
                ].map(({ n, label }) => (
                  <div class="text-center py-2">
                    <p class="font-heading font-bold text-xl text-gold">{n}</p>
                    <p class="font-body text-[10px] text-warm-gray leading-snug mt-0.5">{label}</p>
                  </div>
                ))}
              </div>
            </div>

          </aside>
        </div>
      </div>
    </section>
  )}

  <PartnershipChatPopup />

</Base>
